# ── Copy this file to .env and fill in your secrets ──────────────────────────
# cp .env.example .env

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC

# ── LLM provider ─────────────────────────────────────────────────────────────
# Provider: anthropic | openai | ollama | nim | gemini
LLM_PROVIDER=anthropic
# Model ID (claude-sonnet-4-6, gpt-4o, llama3, etc.)
LLM_MODEL=claude-sonnet-4-6
# API key — required for Anthropic / OpenAI; leave blank for Ollama
LLM_API_KEY=sk-ant-api

# ── MQTT external ports (host-side) ──────────────────────────────────────────
MQTT_EXTERNAL_PORT=1883
MQTT_WS_EXTERNAL_PORT=9001

# ── Fuseki ────────────────────────────────────────────────────────────────────
FUSEKI_EXTERNAL_PORT=3030
# Change before first run — stored in the Fuseki volume
FUSEKI_ADMIN_PASSWORD=wactorz-secret

# ── Wactorz server ──────────────────────────────────────────────────────────
API_EXTERNAL_PORT=8080
WS_EXTERNAL_PORT=8081
RUST_LOG=wactorz=info,tower_http=warn

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_EXTERNAL_PORT=3000

# ── Home Assistant ────────────────────────────────────────────────────────────
# HA runs with network_mode: host — accessible at http://<host>:8123
# No port mapping needed here.
VITE_HA_URL=http://localhost:8123
VITE_HA_TOKEN=
# ── Wactorz ↔ Home Assistant integration (for e2e / chat tests) ─────────────
# Long-lived access token created in HA → Profile → Long-lived access tokens
HA_URL=http://192.168.1.2:8123
HA_TOKEN=

# ── HomeAssistantStateBridgeAgent ─────────────────────────────────────────────
# Base MQTT topic for state change events (default: homeassistant/state_changes)
HA_STATE_BRIDGE_OUTPUT_TOPIC=homeassistant/state_changes
# Comma-separated allow-list of HA entity domains to forward.
# Leave blank to forward all domains (e.g. "light,switch,sensor,binary_sensor").
HA_STATE_BRIDGE_DOMAINS=
# Publish to per-entity sub-topics ({base}/{domain}/{entity_id})?
# Set to 0 to send all events to the single base topic instead.
HA_STATE_BRIDGE_PER_ENTITY=0


# VITE_GOOGLE_AI_KEY=
# NIM_API_KEY=nvapi-
# YOUTUBE_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=
# GOOGLE_SEARCH_API_KEY=
# DEEPSEEK_API_KEY=sk-
# MISTRAL_API_KEY=

# ─── Chat Interfaces ─────────────────────────────────────
# Discord: create a bot at https://discord.com/developers/applications, enable Message Content Intent
DISCORD_BOT_TOKEN=MTQ4NDE1MjE3NzI4NTkyMjgzNg.G-tPIB.nuoRiRSTSVyH3d99UaUdrdUUI5F9eVSLl10HaY

# Telegram: create a bot via @BotFather → /newbot
# Get your user ID by starting the bot and sending /start — it replies with your ID
# strongly recommended — locks the bot to only your Telegram account
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
