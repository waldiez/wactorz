# ── Copy this file to .env and fill in your secrets ──────────────────────────
# cp .env.example .env

# Interface to use: cli, web, etc.
INTERFACE=cli
# Set to 1 for Python-first local development defaults.
# In dev mode the backend defaults to Python, the Python interface defaults to
# REST, and the default Python API port becomes 8080 so the SPA can hit `/api`.
AGENTFLOW_DEV_MODE=0
# Port for the application to run on
PORT=8000
# API key for external services (leave blank if not needed)
API_KEY=

# ── Timezone ──────────────────────────────────────────────────────────────────
# Set the timezone for the application (e.g., UTC, America/New_York)
TZ=UTC

# ── LLM provider ─────────────────────────────────────────────────────────────
# Provider for the language model: anthropic, openai, or ollama
LLM_PROVIDER=anthropic
# Model ID for the selected provider (e.g., claude-sonnet-4-6, gpt-4o, llama3)
LLM_MODEL=claude-sonnet-4-6
# API key for the LLM provider (required for Anthropic/OpenAI; leave blank for Ollama)
LLM_API_KEY=
# URL for Ollama (if using Ollama as the provider)
OLLAMA_URL=
# API key for NIM (if applicable)
NIM_API_KEY=
# API key for NVIDIA services (if applicable)
NVIDIA_API_KEY=

# ── MQTT config (host-side) ──────────────────────────────────────────
# MQTT broker host (default: localhost)
MQTT_HOST=localhost
# MQTT broker port (default: 1883)
MQTT_PORT=1883
# External port for MQTT broker
MQTT_EXTERNAL_PORT=1883
# External port for MQTT WebSocket connections
MQTT_WS_EXTERNAL_PORT=9001

# ── Fuseki ────────────────────────────────────────────────────────────────────
# External port for Fuseki server
FUSEKI_EXTERNAL_PORT=3030
# Admin password for Fuseki (change before first run; stored in the Fuseki volume)
FUSEKI_ADMIN_PASSWORD=agentflow-secret

# ── AgentFlow server ──────────────────────────────────────────────────────────
# External port for the AgentFlow API
API_EXTERNAL_PORT=8080
# External port for the AgentFlow WebSocket server
WS_EXTERNAL_PORT=8081
# Logging configuration for the AgentFlow server
RUST_LOG=agentflow=info,tower_http=warn

# ── Dashboard ─────────────────────────────────────────────────────────────────
# External port for the dashboard
DASHBOARD_EXTERNAL_PORT=3000
# WebSocket port for the dashboard
WS_PORT=8888

# ── Home Assistant ────────────────────────────────────────────────────────────
# URL for the Home Assistant instance (default: http://localhost:8123)
# No port mapping needed as HA runs with network_mode: host
HA_URL=http://localhost:8123
# Long-lived access token for Home Assistant
HA_TOKEN=

# ── HomeAssistantStateBridgeAgent ─────────────────────────────────────────────
# Base MQTT topic for state change events (default: homeassistant/state_changes)
HA_STATE_BRIDGE_OUTPUT_TOPIC=homeassistant/state_changes
# Comma-separated allow-list of HA entity domains to forward.
# Leave blank to forward all domains (e.g. "light,switch,sensor,binary_sensor").
HA_STATE_BRIDGE_DOMAINS=
# Publish to per-entity sub-topics ({base}/{domain}/{entity_id})?
# Set to 0 to send all events to the single base topic instead.
HA_STATE_BRIDGE_PER_ENTITY=1

# Twilio configuration for WhatsApp integration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ── AgentFlow ↔ Home Assistant integration (for e2e / chat tests) ─────────────
# Long-lived access token created in HA → Profile → Long-lived access tokens
VITE_GOOGLE_AI_KEY=
NIM_API_KEY=nvapi-
YOUTUBE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
GOOGLE_SEARCH_API_KEY=
DEEPSEEK_API_KEY=sk-
MISTRAL_API_KEY=

# ── NautilusAgent (SSH / rsync bridge) ────────────────────────────────────────
# Path to the SSH private key used by NautilusAgent for all remote operations.
# Leave blank to use SSH's default key search (~/.ssh/id_ed25519, id_rsa, …).
# Generate a dedicated deploy key:
#   ssh-keygen -t ed25519 -C "agentflow-deploy" -f ~/.ssh/agentflow_deploy
#   ssh-copy-id -i ~/.ssh/agentflow_deploy.pub user@host
# Then set:
NAUTILUS_SSH_KEY=
# ~/.ssh/agentflow_deploy

# Enforce strict SSH host-key checking (0 = accept-new, 1 = strict).
# Set to 1 in production once all hosts are known.
NAUTILUS_STRICT_HOST_KEYS=0

# Per-connection SSH timeout in seconds.
NAUTILUS_CONNECT_TIMEOUT=10

# Maximum wall-clock seconds for any single exec / rsync command.
NAUTILUS_EXEC_TIMEOUT=120

# Extra rsync flags appended to every sync/push (space-separated).
# Example: --delete --exclude=.git
NAUTILUS_RSYNC_FLAGS=

# ── Deployment target (used by scripts/deploy.sh and NautilusAgent) ───────────
# Remote host in user@hostname format.
DEPLOY_HOST=
# user@your-server.example.com

# Remote base directory where AgentFlow is installed.
DEPLOY_PATH=/opt/agentflow

# SSH port on the remote host.
DEPLOY_SSH_PORT=22

# Command to restart the AgentFlow service after a deploy.
# Adjust if you use a different service manager or a custom wrapper.
DEPLOY_RESTART_CMD=systemctl restart agentflow

# Set to 1 to deploy only the frontend (skip binary build/upload).
# Useful for quick frontend-only fixes.
DEPLOY_SKIP_BINARY=0

# Cargo cross-compilation target.  Leave blank to build for the host arch.
# For linux/amd64 from macOS: x86_64-unknown-linux-gnu
# (requires the target + a cross-linker, or use Docker via package-native.sh)
CARGO_BUILD_TARGET=

# nginx mode for the remote host:
#   docker   — (default) start the Docker nginx container from compose.native.yaml.
#              Good for fresh servers with no existing web server.
#   existing — host already runs nginx (e.g. with certbot/SSL).  deploy.sh will
#              upload infra/nginx/agentflow-snippet.conf to DEPLOY_NGINX_CONF and
#              reload nginx.  Paste `include DEPLOY_NGINX_CONF;` inside your SSL
#              server block if you haven't already.
DEPLOY_NGINX_MODE=docker

# Where to upload the nginx location snippet when DEPLOY_NGINX_MODE=existing.
# Must be writable with sudo on the remote.
# Adjust to match your nginx include glob (e.g. /etc/nginx/sites-enabled/agentflow.conf).
DEPLOY_NGINX_CONF=/etc/nginx/conf.d/agentflow.conf

# ── WeatherAgent ──────────────────────────────────────────────────────────────
# Default city/location returned when @weather-agent is called with no argument.
# Accepts city names, country names, or lat,lon coordinates.
WEATHER_DEFAULT_LOCATION=London
