# ── Copy this file to .env and fill in your secrets ──────────────────────────
# cp .env.example .env

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC

# ── LLM provider ─────────────────────────────────────────────────────────────
# Provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic
# Model ID (claude-sonnet-4-6, gpt-4o, llama3, etc.)
LLM_MODEL=claude-sonnet-4-6
# API key — required for Anthropic / OpenAI; leave blank for Ollama
LLM_API_KEY=sk-ant-sth

# ── MQTT external ports (host-side) ──────────────────────────────────────────
MQTT_EXTERNAL_PORT=1883
MQTT_WS_EXTERNAL_PORT=9001

# ── Fuseki ────────────────────────────────────────────────────────────────────
FUSEKI_EXTERNAL_PORT=3030
# Change before first run — stored in the Fuseki volume
FUSEKI_ADMIN_PASSWORD=wactorz-secret

# ── Wactorz server ──────────────────────────────────────────────────────────
API_EXTERNAL_PORT=8080
WS_EXTERNAL_PORT=8081
RUST_LOG=wactorz=info,tower_http=warn

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_EXTERNAL_PORT=3000

# ── Home Assistant ────────────────────────────────────────────────────────────
# HA runs with network_mode: host — accessible at http://<host>:8123
# No port mapping needed here.
VITE_HA_URL=http://localhost:8123
VITE_HA_TOKEN=

# ── Wactorz ↔ Home Assistant integration (for e2e / chat tests) ─────────────
# Long-lived access token created in HA → Profile → Long-lived access tokens
HOMEASSISTANT_URL=http://192.168.1.2:8123
HOMEASSISTANT_TOKEN=

# VITE_GOOGLE_AI_KEY=
# NIM_API_KEY=nvapi-
# YOUTUBE_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=
# GOOGLE_SEARCH_API_KEY=
# DEEPSEEK_API_KEY=sk-
# MISTRAL_API_KEY=

# ── NautilusAgent (SSH / rsync bridge) ────────────────────────────────────────
# Path to the SSH private key used by NautilusAgent for all remote operations.
# Leave blank to use SSH's default key search (~/.ssh/id_ed25519, id_rsa, …).
# Generate a dedicated deploy key:
#   ssh-keygen -t ed25519 -C "wactorz-deploy" -f ~/.ssh/wactorz_deploy
#   ssh-copy-id -i ~/.ssh/wactorz_deploy.pub user@host
# Then set:
NAUTILUS_SSH_KEY=
# ~/.ssh/wactorz_deploy

# Enforce strict SSH host-key checking (0 = accept-new, 1 = strict).
# Set to 1 in production once all hosts are known.
NAUTILUS_STRICT_HOST_KEYS=0

# Per-connection SSH timeout in seconds.
NAUTILUS_CONNECT_TIMEOUT=10

# Maximum wall-clock seconds for any single exec / rsync command.
NAUTILUS_EXEC_TIMEOUT=120

# Extra rsync flags appended to every sync/push (space-separated).
# Example: --delete --exclude=.git
NAUTILUS_RSYNC_FLAGS=

# ── Deployment target (used by scripts/deploy.sh and NautilusAgent) ───────────
# Remote host in user@hostname format.
DEPLOY_HOST=
# user@your-server.example.com

# Remote base directory where Wactorz is installed.
DEPLOY_PATH=/opt/wactorz

# SSH port on the remote host.
DEPLOY_SSH_PORT=22

# Command to restart the Wactorz service after a deploy.
# Adjust if you use a different service manager or a custom wrapper.
DEPLOY_RESTART_CMD="systemctl restart wactorz"

# Set to 1 to deploy only the frontend (skip binary build/upload).
# Useful for quick frontend-only fixes.
DEPLOY_SKIP_BINARY=0

# Cargo cross-compilation target.  Leave blank to build for the host arch.
# For linux/amd64 from macOS: x86_64-unknown-linux-gnu
# (requires the target + a cross-linker, or use Docker via package-native.sh)
CARGO_BUILD_TARGET=

# nginx mode for the remote host:
#   docker   — (default) start the Docker nginx container from compose.native.yaml.
#              Good for fresh servers with no existing web server.
#   existing — host already runs nginx (e.g. with certbot/SSL).  deploy.sh will
#              upload infra/nginx/wactorz-snippet.conf to DEPLOY_NGINX_CONF and
#              reload nginx.  Paste `include DEPLOY_NGINX_CONF;` inside your SSL
#              server block if you haven't already.
DEPLOY_NGINX_MODE=docker

# Where to upload the nginx location snippet when DEPLOY_NGINX_MODE=existing.
# Must be writable with sudo on the remote.
# Adjust to match your nginx include glob (e.g. /etc/nginx/sites-enabled/wactorz.conf).
DEPLOY_NGINX_CONF=/etc/nginx/conf.d/wactorz.conf

# ── WeatherAgent ──────────────────────────────────────────────────────────────
# Default city/location returned when @weather-agent is called with no argument.
# Accepts city names, country names, or lat,lon coordinates.
WEATHER_DEFAULT_LOCATION=Athens


# ─── AI Models ───────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GOOGLE_GEMINI_API_KEY=
GROQ_API_KEY=
NIM_API_KEY=

# ─── Voice ───────────────────────────────────────────────
SYNAPSE_WAKE_WORD=hey_synapse
SYNAPSE_STT_MODE=webspeech
SYNAPSE_TTS_MODE=browser
SYNAPSE_VOICE_LANG=en-US

# ─── Shell ───────────────────────────────────────────────
SYNAPSE_DEFAULT_SCENE=greeter
SYNAPSE_GPU_MODE=auto
SYNAPSE_THEME=dark
SYNAPSE_INACTIVITY_SECS=300

# ─── Core Daemon ─────────────────────────────────────────
SYNAPSE_SOCKET=/run/synapse/core.sock
SYNAPSE_LOG=synapse_core=info,synapse_ai=debug

# ─── Mobile Bridge ───────────────────────────────────────
SYNAPSE_MOBILE_PORT=8766
SYNAPSE_WEBRTC_STUN=stun:stun.l.google.com:19302

# ─── Development ─────────────────────────────────────────
VITE_DEV_SERVER_PORT=1420
GDK_BACKEND=x11
