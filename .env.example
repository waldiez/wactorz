# ── Copy this file to .env and fill in your secrets ──────────────────────────
# cp .env.example .env

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC

# ── LLM provider ─────────────────────────────────────────────────────────────
# Provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic
# Model ID (claude-sonnet-4-6, gpt-4o, llama3, etc.)
LLM_MODEL=claude-sonnet-4-6
# API key — required for Anthropic / OpenAI; leave blank for Ollama
LLM_API_KEY=

# ── MQTT external ports (host-side) ──────────────────────────────────────────
MQTT_EXTERNAL_PORT=1883
MQTT_WS_EXTERNAL_PORT=9001

# ── Fuseki ────────────────────────────────────────────────────────────────────
FUSEKI_EXTERNAL_PORT=3030
# Change before first run — stored in the Fuseki volume
FUSEKI_ADMIN_PASSWORD=agentflow-secret

# ── AgentFlow server ──────────────────────────────────────────────────────────
API_EXTERNAL_PORT=8080
WS_EXTERNAL_PORT=8081
RUST_LOG=agentflow=info,tower_http=warn

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_EXTERNAL_PORT=3000

# ── Home Assistant ────────────────────────────────────────────────────────────
# HA runs with network_mode: host — accessible at http://<host>:8123
# No port mapping needed here.

# ── AgentFlow ↔ Home Assistant integration (for e2e / chat tests) ─────────────
# Long-lived access token created in HA → Profile → Long-lived access tokens
HOMEASSISTANT_URL=http://localhost:8123
HOMEASSISTANT_TOKEN=

VITE_GOOGLE_AI_KEY=
NIM_API_KEY=nvapi-
YOUTUBE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
GOOGLE_SEARCH_API_KEY=
DEEPSEEK_API_KEY=sk-
MISTRAL_API_KEY=

# ── NautilusAgent (SSH / rsync bridge) ────────────────────────────────────────
# Path to the SSH private key used by NautilusAgent for all remote operations.
# Leave blank to use SSH's default key search (~/.ssh/id_ed25519, id_rsa, …).
# Generate a dedicated deploy key:
#   ssh-keygen -t ed25519 -C "agentflow-deploy" -f ~/.ssh/agentflow_deploy
#   ssh-copy-id -i ~/.ssh/agentflow_deploy.pub user@host
# Then set:
NAUTILUS_SSH_KEY=
# ~/.ssh/agentflow_deploy

# Enforce strict SSH host-key checking (0 = accept-new, 1 = strict).
# Set to 1 in production once all hosts are known.
NAUTILUS_STRICT_HOST_KEYS=0

# Per-connection SSH timeout in seconds.
NAUTILUS_CONNECT_TIMEOUT=10

# Maximum wall-clock seconds for any single exec / rsync command.
NAUTILUS_EXEC_TIMEOUT=120

# Extra rsync flags appended to every sync/push (space-separated).
# Example: --delete --exclude=.git
NAUTILUS_RSYNC_FLAGS=

# ── Deployment target (used by scripts/deploy.sh and NautilusAgent) ───────────
# Remote host in user@hostname format.
DEPLOY_HOST=
# user@your-server.example.com

# Remote base directory where AgentFlow is installed.
DEPLOY_PATH=/opt/agentflow

# SSH port on the remote host.
DEPLOY_SSH_PORT=22

# Command to restart the AgentFlow service after a deploy.
# Adjust if you use a different service manager or a custom wrapper.
DEPLOY_RESTART_CMD=systemctl restart agentflow

# Set to 1 to deploy only the frontend (skip binary build/upload).
# Useful for quick frontend-only fixes.
DEPLOY_SKIP_BINARY=0

# Cargo cross-compilation target.  Leave blank to build for the host arch.
# For linux/amd64 from macOS: x86_64-unknown-linux-gnu
# (requires the target + a cross-linker, or use Docker via package-native.sh)
CARGO_BUILD_TARGET=
