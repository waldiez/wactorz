# ─────────────────────────────────────────────────────────────────────────────
#  Wactorz — environment template
#  Copy to .env and fill in your values:  cp .env.template .env
# ─────────────────────────────────────────────────────────────────────────────


# ── General ───────────────────────────────────────────────────────────────────

TZ=UTC

# Interface the Python app exposes.
# Options: rest | cli | discord | telegram | whatsapp
INTERFACE=rest

# REST API port
PORT=8000

# Monitor / Web UI port
MONITOR_PORT=8888


# ── LLM provider ─────────────────────────────────────────────────────────────

# Options: anthropic | openai | ollama | nim | gemini | none
LLM_PROVIDER=anthropic

# Model ID — examples per provider:
#   anthropic → claude-sonnet-4-6
#   openai    → gpt-4o
#   ollama    → llama3
#   nim       → meta/llama-3.3-70b-instruct
#   gemini    → gemini-2.5-flash
LLM_MODEL=claude-sonnet-4-6

# Generic key — used for anthropic/openai/nim/gemini.
# Or set the provider-specific key below.
LLM_API_KEY=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
NIM_API_KEY=
NVIDIA_API_KEY=

# Ollama base URL (only needed when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434


# ── MQTT broker ───────────────────────────────────────────────────────────────

MQTT_HOST=localhost #host.docker.internal
MQTT_PORT=1883
MQTT_WS_PORT=9001

# Host-side port mappings for docker compose
MQTT_EXTERNAL_PORT=1883
MQTT_WS_EXTERNAL_PORT=9001


# ── Apache Jena Fuseki ────────────────────────────────────────────────────────

FUSEKI_URL=http://localhost:3030
FUSEKI_USER=admin
# FUSEKI_ADMIN_PASSWORD is used by the container to set the admin password.
# FUSEKI_PASSWORD is used by wactorz-fuseki bridge to authenticate.
# Keep them in sync.
FUSEKI_ADMIN_PASSWORD=admin
FUSEKI_PASSWORD=admin
FUSEKI_EXTERNAL_PORT=3030


# ── Docker compose external ports ─────────────────────────────────────────────

# Python stack
REST_EXTERNAL_PORT=8000
MONITOR_EXTERNAL_PORT=8888

# Rust stack
API_EXTERNAL_PORT=8080
WS_EXTERNAL_PORT=8081

# Dashboard (nginx, rust profile)
DASHBOARD_EXTERNAL_PORT=80

# Rust log filter
RUST_LOG=wactorz=info,tower_http=warn


# ── API security ──────────────────────────────────────────────────────────────

# Optional bearer token for the REST API. Leave blank to disable auth.
API_KEY=


# ── Home Assistant integration ────────────────────────────────────────────────

# Long-lived access token: HA → Profile → Long-lived access tokens
HA_URL=http://192.168.1.2:8123
HA_TOKEN=

# State-bridge: which entity domains to forward over MQTT.
# Leave blank to forward everything. Example: light,switch,sensor,binary_sensor
HA_STATE_BRIDGE_DOMAINS=

# Base MQTT topic for HA state-change events
HA_STATE_BRIDGE_OUTPUT_TOPIC=homeassistant/state_changes

# 1 = publish each entity to its own sub-topic ({base}/{domain}/{entity_id})
# 0 = send all events to the single base topic
HA_STATE_BRIDGE_PER_ENTITY=0

# Advanced — leave blank for defaults
HA_MAP_AGENT_OUTPUT_TOPIC=
HA_MAP_AGENT_TARGET_ACTOR=


# ── Chat interfaces ───────────────────────────────────────────────────────────

# Discord — https://discord.com/developers/applications
#           enable "Message Content Intent" in the bot settings
DISCORD_BOT_TOKEN=

# Telegram — create a bot via @BotFather → /newbot
#             get your user ID by sending /start to your bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# WhatsApp via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

